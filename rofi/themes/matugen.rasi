* {
    background-color: rgba(47, 38, 40, 0.85);
    highlight:     bold #ffffff;
}
window {
    background-color: rgba(47, 38, 40, 0.85);
    border-radius: 0 15mm 15mm 0;

    padding: 10mm;

    height: 90%;
    width: 125mm;
    border: 3px 3px 3px 0;
    border-color: #f2508d;
    text-color: #ffffff;

    location: west;
    anchor:   west;
}
inputbar {
    background-color: transparent;
    text-color:       #ecd7db;
    children: [prompt, entry, textbox-end];
    spacing: 1mm;
}
prompt {
  border-radius: 5mm 0mm 0mm 5mm;
  width: 15mm;
}
textbox-end {
  border-radius: 0mm 5mm 5mm 0mm;
  width: 15mm;
  expand: false;
}
entry {
  background-color: #514346;
}
prompt, entry, textbox-end, num-filtered-rows {
  background-color: #4c4244;
  text-color: inherit;
  padding: 2mm;
  vertical-align: 0.5;
}
element {
    border-radius: 5mm;
    children: [element-icon];
}
textbox-current-entry {
    border-radius: 5mm;
    background-color: #c67b90;
    text-color: #000000;
    placeholder: "n/a";
    padding: 2mm;
    horizontal-align: 0.5;
  }
element-icon {
  expand: true;
  size: 10mm;
  vertial-align: 0.5;
  horizontal-align: 0.5;
  padding: 2mm;
}
mainbox {
    expand: true;
    background-color: transparent;
    spacing:  5mm;
    children: [
                inputbar,
                listview,
                icon-current-entry,
                textbox-current-entry
    ];
}
icon-current-entry {
    size: 50mm;
  }
listview {
    padding: 0em;
    dynamic: false;
    lines: 0;
    columns: 8;
    flow: horizontal;
}
element selected  normal {
    background-color: #ffd0db;
    text-color: #471226;
}
element normal active {
    text-color: #ffd4b1;
}
element normal urgent {
    text-color: #ffd2cc;
}
element alternate normal {
}
element alternate active {
    text-color: #ffd4b1;
}
element alternate urgent {
    text-color: #ff5449;
}
element selected active {
    background-color: #b38861;
    text-color: #000000;
}
element selected urgent {
    background-color: #ff5449;
    text-color: #000000;
}
error-message {
    expand: true;
    background-color: #ff5449;
    border-color: #ffd2cc;
    border: 2px;
    padding: 1em;
}
